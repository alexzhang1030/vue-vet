[
  {
    "name": "modules::named_multihop::ref::nested_guards",
    "modules": [
      {
        "id": "producer.ts",
        "source": "import { ref } from 'vue'; export const signal = ref(0);",
        "language": "ts",
        "kind": "script"
      },
      {
        "id": "first.ts",
        "source": "export { signal as middle } from './producer';",
        "language": "ts",
        "kind": "script"
      },
      {
        "id": "second.ts",
        "source": "export { middle as finalSignal } from './first';",
        "language": "ts",
        "kind": "script"
      },
      {
        "id": "consumer.ts",
        "source": "import { ref, watchEffect } from 'vue'; import { finalSignal as payload } from './second'; const ready = ref(false); const enabled = ref(false); watchEffect(() => { if (!ready.value) return; if (enabled.value) { try { for (const item of [1]) { if (item) { payload.value; } } } finally { sink(); } } });",
        "language": "ts",
        "kind": "script"
      }
    ],
    "links": [
      {
        "from": "first.ts",
        "specifier": "./producer",
        "to": "producer.ts"
      },
      {
        "from": "second.ts",
        "specifier": "./first",
        "to": "first.ts"
      },
      {
        "from": "consumer.ts",
        "specifier": "./second",
        "to": "second.ts"
      }
    ],
    "expected": {
      "module": "consumer.ts",
      "binding": "payload",
      "kind": "conditional",
      "guards": [
        "ready"
      ],
      "trace": true
    }
  },
